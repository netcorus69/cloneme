*.onnx filter=lfs diff=lfs merge=lfs -text
# Force all .c and .h files to be recognized as C
*.c linguist-language=C
*.h linguist-language=C

# Exclude backup and test files from language stats
backup/* linguist-vendored
face*.c linguist-vendored
*.blend linguist-vendored
*.bak linguist-vendored
*.log linguist-vendored

